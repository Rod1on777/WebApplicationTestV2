@using WebAppV3.Models
@model MainPageViewModel

@{
    ViewData["Title"] = "Terraform Configuration";
}

<div class="container mt-5 mb-5">
  <div class="d-flex align-items-center mb-4">
    <a asp-action="Index" asp-controller="Home" class="btn btn-outline-secondary me-3 rounded-3">
      ⬅ Home
    </a>
    <h1 class="fw-bold font-header mb-0">Infrastructure as Code</h1>
  </div>
  
  <section class="infra-section">
    <div class="infra-container">
      <div class="infra-content">
        
        <div class="infra-card">
          <h3 class="infra-subtitle">Automated AWS Deployment <span>(Terraform & Ubuntu ARM64)</span></h3>
          <p class="infra-text">
            The entire hosting environment is partly provisioned using <strong>Terraform</strong>, ensuring strict reproducibility and state management for the cloud resources in the <code>ap-southeast-2</code> (Sydney) region.
          </p>
          
          <div class="infra-highlight">
            <h4>Secure Bootstrapping</h4>
            <p>
              Through EC2 <code>user_data</code>, the instance automatically provisions its runtime environment on first boot. Essential secrets like OAuth credentials and the Lambda Endpoint are securely injected into system-wide environment variables (<code>/etc/environment</code>), eliminating hardcoded configuration files.
            </p>
          </div>
          
          <p class="infra-text footer-text">
            Network boundaries are rigidly defined via an <strong>AWS Security Group</strong>. It locks down SSH access exclusively to a dynamic developer IP while maintaining wide HTTP availability for application users.
          </p>
        </div>
      </div>

      <div class="infra-visual">
        
        <div class="infra-layer">
          <div class="infra-node perimeter">
            <span class="node-tag text-public">Gateway</span>
            <div class="node-icon bg-public">Elastic IP</div>
            <span class="node-loc">Static Public IP</span>
          </div>
        </div>
        
        <div class="infra-arrow-down">
          <div class="sg-badge">Security Group</div>
          <div class="sg-rules">
            <span>Port 80: 0.0.0.0/0</span>
            <span>Port 22: My IP Only</span>
          </div>
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 5V19M12 19L6 13M12 19L18 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        
        <div class="infra-layer">
          <div class="infra-node compute">
            <span class="node-tag text-compute">EC2 Compute</span>
            <div class="node-icon bg-compute">t4g.micro (ARM)</div>
            <span class="node-loc">Ubuntu 24.04 LTS</span>
          </div>
        </div>
        
        <div class="env-box">
          <div class="env-title">
            <span class="pulse-dot"></span> User Data Bootstrapping
          </div>
          <div class="env-code">
            <code>export AWSLambda__URL="..."</code>
            <code>export Authentication__Google__*</code>
          </div>
        </div>

      </div>
      
    </div>
  </section>


  <div class="row g-4">
        <div class="">

            <div class="terra-card shadow-sm border-0 rounded-4 p-4 mb-4">
                <h3 class="fw-bold mb-3 text-white">📄 Terraform configuration</h3>
                <div class="terraform-code-container">
                  <pre class="terraform-code"><code>
variable "my_ip" {
  description = "My IP for SSH"
  type        = string
}

variable "key_name" {
  description = "SSH key name in AWS"
  type        = string
}

variable "lambda_url" {
  description = "lambda url in AWS"
  type        = string
}

variable "google_client_id" {
  description = "google_client_id"
  type        = string
}

variable "google_client_secret" {
  description = "google_client_secret"
  type        = string
}

provider "aws" {
  region = "ap-southeast-2" # Регион Сидней
}

# Security Group
resource "aws_security_group" "web_sg" {
  name = "web-server-sg"

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = [var.my_ip]
  }

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

# EC2 Инстанс
resource "aws_instance" "app_server" {
  ami           = "ami-07f95dfb1e3d841ce"
  instance_type = "t4g.micro"
  key_name      = var.key_name

  vpc_security_group_ids = [aws_security_group.web_sg.id]

  tags = {
    Name = "DotNetAppServer-ARM"
  }

  user_data = EOF
              #!\bin\bash
              echo "Authentication__Google__ClientId=${var.google_client_id}" >> /etc/environment
              echo "Authentication__Google__ClientSecret=${var.google_client_secret}" >> /etc/environment
              echo "AWSLambda__URL=${var.lambda_url}" >> /etc/environment
              
              source /etc/environment
              EOF
}

# Elastic IP
resource "aws_eip" "app_eip" {
  instance = aws_instance.app_server.id
  domain   = "vpc"
}

output "public_ip" {
  value = aws_eip.app_eip.public_ip
}
                    </code></pre>
                </div>
            </div>
        </div>

        
    </div>
</div>