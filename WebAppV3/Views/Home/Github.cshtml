@using WebAppV3.Models
@model MainPageViewModel

@{
    ViewData["Title"] = "GitHub Actions Configuration";
}

<div class="container mt-5 mb-5">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" asp-controller="Home" class="btn btn-outline-secondary me-3 rounded-3">
            ⬅ Home
        </a>
        <h1 class="fw-bold font-header mb-0">Continuous Deployment</h1>
    </div>
    <section class="cicd-section">
      <div class="cicd-container">
        
        <div class="cicd-visual">
          <div class="pipeline-header">
            <span class="branch-badge">branch: master</span>
            <div class="pipeline-status">
              <span class="status-dot pulsing"></span> Running
            </div>
          </div>
          
          <div class="pipeline-steps">
            <div class="step-item done">
              <div class="step-icon">✓</div>
              <div class="step-details">
                <span class="step-name">Set Up Job</span>
                <span class="step-tech">Actions SDK & .NET 10</span>
              </div>
            </div>
            
            <div class="step-item done">
              <div class="step-icon">✓</div>
              <div class="step-details">
                <span class="step-name">Run actions/checkout@v3</span>
                <span class="step-tech">linux-arm64 --self-contained</span>
              </div>
            </div>
            
            <div class="step-item done">
              <div class="step-icon">✓</div>
              <div class="step-details">
                <span class="step-name">Setup .NET</span>
              </div>
            </div>
            
            <div class="step-item done">
              <div class="step-icon">✓</div>
              <div class="step-details">
                <span class="step-name">Publish</span>
              </div>
            </div>
            
            <div class="step-item done">
              <div class="step-icon">✓</div>
              <div class="step-details">
                <span class="step-name">List files (Check)</span>
              </div>
            </div>
            
            <div class="step-item active">
              <div class="step-icon-active">
                <svg class="spinner" viewBox="0 0 50 50">
                  <circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle>
                </svg>
              </div>
              <div class="step-details">
                <span class="step-name">Copy files via SCP</span>
                <span class="step-tech">appleboy/scp-action</span>
              </div>
            </div>
            
            <div class="step-item pending">
              <div class="step-icon-pending"></div>
              <div class="step-details">
                <span class="step-name">Restart service</span>
              </div>
            </div>
            
            <div class="step-item pending">
              <div class="step-icon-pending"></div>
              <div class="step-details">
                <span class="step-name">Post Setup .NET</span>
              </div>
            </div>
            
            <div class="step-item pending">
              <div class="step-icon-pending"></div>
              <div class="step-details">
                <span class="step-name">Post Run actions/checkout@v3</span>
              </div>
            </div>
            
            <div class="step-item pending">
              <div class="step-icon-pending"></div>
              <div class="step-details">
                <span class="step-name">Complete job</span>
              </div>
            </div>
          </div>
        </div>

        <div class="cicd-content">
          
          <div class="cicd-card">
            <h3 class="cicd-subtitle">Automated CI/CD Pipeline <span>(GitHub Actions & Systemd)</span></h3>
            <p class="cicd-text">
              Every push to the <code>master</code> branch triggers an automated deployment pipeline on <strong>GitHub-hosted runners</strong>, removing manual friction from the release cycle.
            </p>
            
            <div class="cicd-highlight">
              <h4>Cross-Compilation Strategy</h4>
              <p>
                The runner compiles the source code specifically targetting the <code>linux-arm64</code> architecture with the <code>--self-contained</code> flag. This bundles the <strong>.NET 10 runtime</strong> directly into the binaries, ensuring the production EC2 server requires zero framework pre-installations.
              </p>
            </div>
            
            <p class="cicd-text footer-text">
              Once compiled, deployment artifacts are securely pushed via <strong>encrypted SCP</strong> using GitHub Secrets. The pipeline concludes by opening a precise SSH tunnel to gracefully cycle the <code>systemd</code> service daemon (<code>myapp</code>) with zero user intervention.
            </p>
          </div>
        </div>
        
      </div>
    </section>

    <div class="row g-4">
      <div class="">

        <div class="cicd-card shadow-sm border-0 rounded-4 p-4 mb-4">
          <h3 class="fw-bold mb-3 text-white">📄 GitHub Actions Workflow</h3>
          <div class="cicd-code-container">
            <pre class="cicd-code"><code>
name: Deploy to AWS

on:
  push:
    branches:
      - master

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3

      - name: Setup .NET
        uses: actions/setup-dotnet@v3
        with:
          dotnet-version: '10.0.x'

      - name: Publish
        run: dotnet publish -c Release -r linux-arm64 --self-contained true -o ./publish_output

      - name: List files (Check)
        run: ls -R ./publish_output

      - name: Copy files via SCP
        uses: appleboy/scp-action@master
        with:
          host: ${{ secrets.SERVER_IP }}
          username: ${{ secrets.USER_NAME }}
          key: ${{ secrets.SSH_PRIVATE_KEY }}
          source: "./publish_output/*"
          target: "/home/ec2-user/myapp"
          strip_components: 1 # Убираем один уровень папки, чтобы файлы легли прямо в myapp

      - name: Restart service
        uses: appleboy/ssh-action@master
        with:
          host: ${{ secrets.SERVER_IP }}
          username: ${{ secrets.USER_NAME }}
          key: ${{ secrets.SSH_PRIVATE_KEY }}
          script: |
            sudo systemctl stop myapp
            sudo systemctl start myapp
                    </code></pre>
          </div>
        </div>
      </div>
      
    </div>
</div>