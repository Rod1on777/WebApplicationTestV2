@using WebAppV3.Models
@model Project

@{
    ViewData["Title"] = "Добавить новый проект";
}

<link rel="stylesheet" href="~/css/admin-styles.css" />

<div class="admin-edit-container"> @* Reusing admin-edit-container for similar layout *@
    <div class="admin-edit-row-center">
        <div class="admin-edit-col-md-8">
            <div class="admin-edit-header-group">
                <a href="@Url.Action("Index", "Admin")" class="admin-back-button">
                    ⬅ Назад
                </a>
                <h2 class="admin-edit-title">Добавление нового проекта</h2>
            </div>

            <div class="admin-edit-card">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    
                    <div class="admin-form-group">
                        <label asp-for="Name" class="admin-form-label">Название проекта *</label>
                        <input asp-for="Name" class="admin-form-control" placeholder="Например: Celestial Light" required />
                    </div>

                    <div class="admin-form-row">
                        <div class="admin-form-col-md-6 admin-form-group">
                            <label asp-for="RoleInTeam" class="admin-form-label">Роль в команде</label>
                            <input asp-for="RoleInTeam" class="admin-form-control" placeholder="Например: Solo Developer" />
                        </div>
                        <div class="admin-form-col-md-6 admin-form-group">
                            <label asp-for="DevelopmentTime" class="admin-form-label">Срок разработки</label>
                            <input asp-for="DevelopmentTime" class="admin-form-control" placeholder="Например: 3 месяца" />
                        </div>
                    </div>

                    <div class="admin-form-row">
                        <div class="admin-form-col-md-6 admin-form-group">
                            <label asp-for="TeamMembersCount" class="admin-form-label">Количество человек в команде</label>
                            <input asp-for="TeamMembersCount" type="number" class="admin-form-control" min="1" value="1" />
                        </div>
                        <div class="admin-form-col-md-6 admin-form-group">
                            <label asp-for="SourceCodeLink" class="admin-form-label">Ссылка на исходный код (GitHub)</label>
                            <input asp-for="SourceCodeLink" type="url" class="admin-form-control" placeholder="https://github.com/..." />
                        </div>
                    </div>

                    <div class="admin-form-group">
                        <label asp-for="TechnologyStack" class="admin-form-label">Стек технологий (через запятую)</label>
                        <input asp-for="TechnologyStack" class="admin-form-control" placeholder="Java, Spring Boot, SQLite, Git" />
                    </div>

                    <div class="admin-form-group">
                        <label asp-for="InfoPreview" class="admin-form-label">Краткое описание (для карточки на главной) *</label>
                        <input asp-for="InfoPreview" class="admin-form-control" placeholder="Короткое превью проекта..." required />
                    </div>

                    <div class="admin-form-group">
                        <label asp-for="DetailedInfo" class="admin-form-label">Детальное описание проекта</label>
                        <textarea asp-for="DetailedInfo" class="admin-form-control" rows="4" placeholder="Подробный рассказ о проекте, архитектуре и задачах..."></textarea>
                    </div>

                    <div class="admin-form-group">
                        <label asp-for="ProjectFeatures" class="admin-form-label">Ключевые фичи проекта</label>
                        <textarea asp-for="ProjectFeatures" class="admin-form-control" rows="2" placeholder="Перечисление ключевого функционала..."></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-secondary">Загрузить скриншот проекта</label>
                        <input type="file" name="imageFile" class="form-control rounded-3" accept="image/*" />

                        @if (Model != null && !string.IsNullOrEmpty(Model.Screenshots))
                        {
                            <div class="mt-2">
                                <small class="text-muted d-block">Текущий скриншот:</small>
                                <img src="@Model.Screenshots" class="img-thumbnail mt-1" style="max-height: 100px;" />
                            </div>
                        }
                    </div>

                    <hr class="admin-form-divider">

                    <button type="submit" class="admin-submit-button" style="background-color: #198754; border-color: #198754;"> @* Using inline style for specific button color, could be a new class if needed elsewhere *@
                        💾 Сохранить проект в базу данных
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>