@using WebAppV3.Models
@model Skills

@{
    ViewData["Title"] = "Редактировать скилл";
}

<link rel="stylesheet" href="~/css/admin-styles.css" />

<div class="admin-edit-container">
    <div class="admin-edit-row-center">
        <div class="admin-edit-col-md-8">
            <div class="admin-edit-header-group">
                <a href="@Url.Action("Index", "Admin")" class="admin-back-button">
                    ⬅ Назад
                </a>
                <h2 class="admin-edit-title">Редактирование скилла: @Model.SkillName</h2>
            </div>

            <div class="admin-edit-card">
                <form asp-action="SkillsEdit" method="post" enctype="multipart/form-data">
                    
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="admin-form-group">
                        <label asp-for="SkillName" class="admin-form-label">Название скилла *</label>
                        <input asp-for="SkillName" class="admin-form-control" required />
                        <label asp-for="SkillName" class="admin-form-label">Категория скилла</label>
                        <select asp-for="Category" class="form-select rounded-3">
                            <option value="General">General</option>
                            <option value="Databases">Databases</option>
                            <option value="Algorithms_and_data_structures">Algorithms and data structures</option>
                            <option value="Soft_Skills">Soft Skills</option>
                            <option value="Web_Development">Web Development</option>
                            <option value="Project_assemblers">Project assemblers</option>
                            <option value="Architecture_and_design">Architecture and design</option>
                        </select>
                    </div>

                    <button type="submit" class="admin-submit-button">
                        🔄 Обновить данные скилла
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>