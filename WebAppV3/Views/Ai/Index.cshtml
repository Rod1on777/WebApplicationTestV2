@{
    ViewData["Title"] = "Ai Job Analysys";
}

<section class="architecture-section">
    <div class="arch-container">

        <div class="arch-visual">
            <div class="arch-node center-node">
                <span class="node-tag">Orchestrator</span>
                <div class="node-icon">.NET App</div>
                <span class="node-loc">AWS EC2</span>
            </div>

            <div class="arch-arrow">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="payload-badge">JSON Payload</span>
            </div>

            <div class="arch-node lambda-node">
                <span class="node-tag text-lambda">Serverless</span>
                <div class="node-icon bg-lambda">AWS Lambda</div>
                <span class="node-loc">Python Script</span>
            </div>

            <div class="arch-arrow continuous">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="payload-badge">HTTPS</span>
            </div>

            <div class="arch-node gemini-node">
                <span class="node-tag text-gemini">AI Core</span>
                <div class="node-icon bg-gemini">Gemini API</div>
                <span class="node-loc">flash-lite</span>
            </div>
        </div>
        
        <div class="arch-content">
            <h2 class="arch-title">How it works?</h2>

            <div class="arch-card">
                <h3 class="arch-subtitle">Secure Serverless AI Bridge <span>(AWS Lambda & Python)</span></h3>
                <p class="arch-text">
                    The <strong>.NET application</strong> acts as an orchestrator and forwards a structured JSON payload containing the vacancy data and the developer's skills to an <strong>AWS Lambda Function URL</strong>.
                </p>

                <div class="why-lambda">
                    <h4>Why Lambda?</h4>
                    <p>
                        Processing external API calls can introduce high latency. Offloading this task to AWS Lambda isolates the long-running network request. The main <strong>EC2 server remains free</strong> to handle other user traffic without resource starvation.
                    </p>
                </div>

                <p class="arch-text footer-text">
                    Inside the Lambda container, a lightweight <strong>Python script</strong> structures the final prompt, configures the <code class="ai-code">thinkingBudget</code>, and establishes a direct HTTPS connection to the <strong>Gemini API</strong> (<code class="ai-code">gemini-flash-lite-latest</code>).
                </p>
            </div>
        </div>

    </div>
</section>



<div class="container mt-5">
    <div class="row">
        <div class="col-md-6">
            <div class="ai-card-job card shadow-sm">
                <div class="card-header ai-background">
                    <h5 class="mb-0">AI-Powered Job Analysis</h5>
                </div>
                <div class="ai-card-body">
                    <form id="aiAnalysisForm">
                        <div class="mb-3">
                            <label for="jobTitle" class="form-label">Job Title</label>
                            <input type="text" class="ai-form-control form-control" id="jobTitle" placeholder="for example, Junior Backend Developer" required>
                        </div>
                        <div class="mb-3">
                            <label for="jobDescription" class="form-label">Job Description / Requirements</label>
                            <textarea class="ai-form-control form-control" id="jobDescription" rows="10" placeholder="Paste the job description details here and click the button to start the analysis" required></textarea>
                        </div>
                        <button type="submit" class="btn ai-button w-100" id="btnSubmit">
                            <span id="btnText">Check Match</span>
                            <span id="btnSpinner" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6 mt-4 mt-md-0">
            <div class="ai-card-job card shadow-sm h-100">
                <div class="card-header ai-background-black">
                    <h5 class="mb-0">📋 AI Recruiter Verdict</h5>
                </div>
                <div class="ai-card-body card-body d-flex flex-column justify-content-center align-items-center" id="resultPlaceholder">
                    <p class="text-center" id="initialMessage">Paste the job description and click the button to start the analysis.</p>
                    
                    <div id="analysisResult" class="w-100 d-none">
                        <div class="text-center mb-4">
                            <h6 class="text-uppercase fw-bold">Match Score</h6>
                            <div class="display-3 fw-bold text-success" id="resPercentage">100%</div>
                        </div>
                        
                        <div class="mb-3">
                            <h6><strong>📌 Overall Verdict:</strong></h6>
                            <p id="resSummary" class="text-justify"></p>
                        </div>
                        
                        <div class="mb-3">
                            <h6><strong>✅ Key Strengths (Matching Skills):</strong></h6>
                            <p id="resStrongPoints" class="text-success"></p>
                        </div>
                        
                        <div class="mb-3">
                            <h6><strong>⚠️ Skill Gaps / Areas to Improve</strong></h6>
                            <p id="resMissingSkills" class="text-danger"></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div style="margin-top: 30px;" class="card">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <button type="button" class="btn btn-outline-info tailor-resume-button btn ai-button w-10" id="btn-tailor-resume" onclick="tailorResume()">
            📝 Tailor My Resume
            <span id="tailor-spinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
        </button>
        <button class="btn btn-sm btn-light d-none btn-outline-info tailor-resume-button btn ai-button" id="btn-download-pdf" onclick="triggerPdfDownload()">Download PDF</button>
        <ul class="nav nav-tabs card-header-tabs" id="previewTabs" role="tablist">
            <li class="nav-item">
                <button class="nav-link active text-color-main" id="resume-tab" data-bs-toggle="tab" data-bs-target="#resume-container" type="button">📄 Resume</button>
            </li>
            <li class="nav-item">
                <button class="nav-link text-color-main" id="cover-tab" data-bs-toggle="tab" data-bs-target="#cover-container" type="button">✉️ Cover Letter</button>
            </li>
        </ul>
    </div>
    
    <div class="card-body p-4 tab-content" style="max-height: 850px; overflow-y: auto;">
        <div class="tab-pane fade show active" id="resume-container" role="tabpanel">
            <div id="resume-div"></div>
        </div>
        <div class="tab-pane fade" id="cover-container" role="tabpanel">
            <div id="cover-div"></div>
        </div>
    </div>
</div>

<input type="hidden" id="hdn-html-content" />
<input type="hidden" id="hdn-cover-content" />


@section Scripts {
    <script>
        document.getElementById('aiAnalysisForm').addEventListener('submit', async function (e) {
            e.preventDefault(); // Отменяем стандартную перезагрузку страницы

            const btnSubmit = document.getElementById('btnSubmit');
            const btnText = document.getElementById('btnText');
            const btnSpinner = document.getElementById('btnSpinner');
            const initialMessage = document.getElementById('initialMessage');
            const analysisResult = document.getElementById('analysisResult');

            // Собираем данные из полей ввода
            const requestData = {
                jobTitle: document.getElementById('jobTitle').value,
                jobDescription: document.getElementById('jobDescription').value
            };

            // Включаем состояние загрузки (лоадер)
            btnSubmit.disabled = true;
            btnText.innerText = "Analyzing stack...";
            btnSpinner.classList.remove('d-none');
            
            // Временно прячем старые результаты или приветствие
            initialMessage.innerText = "AI is reviewing the job posting requirements and matching them with skills database. Please wait...";
            analysisResult.classList.add('d-none');

            try {
                // Делаем асинхронный запрос к нашему контроллеру AiController
                const response = await fetch('/Ai/Analyze', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(requestData)
                });

                if (!response.ok) {
                    throw new Error('An error occurred while contacting the server.');
                }

                const result = await response.json();

                // Прячем системное сообщение и показываем блок с результатами
                initialMessage.classList.add('d-none');
                analysisResult.classList.remove('d-none');

                // Наполняем элементы данными из JSON, который пришел от Gemini
                document.getElementById('resPercentage').innerText = result.matchPercentage + "%";
                document.getElementById('resSummary').innerText = result.summary;
                document.getElementById('resStrongPoints').innerText = result.strongPoints;
                document.getElementById('resMissingSkills').innerText = result.missingSkills;

                // Динамически меняем цвет процента в зависимости от совпадения
                const percentElem = document.getElementById('resPercentage');
                if (result.matchPercentage >= 75) {
                    percentElem.className = "display-3 fw-bold text-success"; // Зеленый
                } else if (result.matchPercentage >= 40) {
                    percentElem.className = "display-3 fw-bold text-warning"; // Желтый
                } else {
                    percentElem.className = "display-3 fw-bold text-danger"; // Красный
                }

            } catch (error) {
                // Если что-то пошло не так, выводим ошибку пользователю
                initialMessage.classList.remove('d-none');
                initialMessage.innerHTML = `<span class="text-danger">❌ Error: ${error.message}</span>`;
            } finally {
                // Возвращаем кнопку в исходное состояние
                btnSubmit.disabled = false;
                btnText.innerText = "Check Match";
                btnSpinner.classList.add('d-none');
            }
        });
    </script>
}